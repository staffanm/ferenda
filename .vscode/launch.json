{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}/site",            
            "console": "integratedTerminal",
            "env": {"PYTHONPATH": "${workspaceFolder}"}
        },
        {
            "name": "Python Debugger: ferenda-build",
            "type": "debugpy",
            "request": "launch",
            "program": "ferenda-build.py",
            "cwd": "${workspaceFolder}/site",            
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {"PYTHONPATH": "${workspaceFolder}"},
            "args": ["${input:args}"]
        },        {
            "name": "Python Debugger: Remote Attach",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "."
                }
            ]
        }
    ],
    "inputs": [
        {
          "id": "args",
          "type": "promptString",
          "description": "argument till ferenda-build",
          "default": "eurlexacts download"
        }
    ]
}