if [ -f .python-version ]; then
  PY_VER="$(cat .python-version)"
else
  PY_VER="3.11"
fi
if ! command -v uv >/dev/null 2>&1; then
  echo "ERROR: uv not found. Install uv first." >&2
  exit 1
fi
if [ ! -d .venv ]; then
  uv venv --python "$PY_VER"
fi
PATH_add ".venv/bin"
export VIRTUAL_ENV="$PWD/.venv"

# Intentionally no `uv sync` here. The working tree carries ~79 GB of generated
# output under site/, and uv/setuptools stall walking it on every shell entry
# (and concurrent reloads pile up on uv's lock). This dir just activates the
# venv -- run `uv sync` by hand after changing dependencies.

dotenv_if_exists
